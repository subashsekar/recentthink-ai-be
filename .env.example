# ---------------------------------------------------------------------------
# RecentThink environment configuration
# Copy this file to `.env` and adjust the values for your environment.
# Never commit your real `.env` file.
# ---------------------------------------------------------------------------

# Core
ENVIRONMENT=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://recentthink:recentthink@localhost:5432/recentthink

# Security / Auth
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
