# Copy this file to `.env` and replace every placeholder before starting.
# Never commit the completed `.env` file.

# Application
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
POSTGRES_USER=get-your-database-user
POSTGRES_PASSWORD=get-your-database-password
POSTGRES_DB=get-your-database-name
POSTGRES_PORT=5432

# Authentication
SECRET_KEY=get-your-key
INTERNAL_SERVICE_TOKEN=get-your-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial super administrator
# All four values are required. The account is created only when no
# SUPER_ADMIN account already exists.
SUPER_ADMIN_EMAIL=get-your-email
SUPER_ADMIN_PASSWORD=get-your-password
SUPER_ADMIN_FIRST_NAME=get-your-first-name
SUPER_ADMIN_LAST_NAME=get-your-last-name

# AI provider
OPENROUTER_API_KEY=get-your-key
OPENROUTER_MODEL=get-your-model
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional provider keys
OPENAI_API_KEY=get-your-key
GOOGLE_API_KEY=get-your-key

# Email (safe local default)
EMAIL_PROVIDER=console

# To send real email, change EMAIL_PROVIDER to smtp and configure:
# SMTP_HOST=get-your-smtp-host
# SMTP_PORT=587
# SMTP_USERNAME=get-your-smtp-username
# SMTP_PASSWORD=get-your-password
# SMTP_USE_TLS=true

# Browser clients allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Local file storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/storage
STORAGE_PUBLIC_BASE_URL=http://localhost:8085/media

# Optional Supabase storage
# STORAGE_BACKEND=supabase
# SUPABASE_URL=get-your-url
# SUPABASE_SERVICE_ROLE_KEY=get-your-key
# SUPABASE_STORAGE_BUCKET=get-your-bucket-name
